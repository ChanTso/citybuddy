{
  "openapi": "3.1.0",
  "info": {"title": "CityBuddy agent API", "version": "CB-103"},
  "paths": {
    "/api/sessions": {
      "post": {
        "operationId": "createSupportSession",
        "security": [{"directUserBearer": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"type": "object", "additionalProperties": false, "maxProperties": 0}
            }
          }
        },
        "responses": {
          "201": {
            "description": "Opaque server-owned support session",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["sessionId"],
                  "properties": {"sessionId": {"type": "string", "minLength": 1, "maxLength": 64}}
                }
              }
            }
          },
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "403": {"$ref": "#/components/responses/Forbidden"},
          "422": {"$ref": "#/components/responses/InvalidRequest"}
        }
      }
    },
    "/api/chat": {
      "post": {
        "operationId": "completeSupportTurn",
        "security": [{"directUserBearer": []}],
        "parameters": [
          {
            "name": "X-Session-Id",
            "in": "header",
            "required": true,
            "schema": {"type": "string", "minLength": 1, "maxLength": 64}
          },
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": true,
            "schema": {"type": "string", "minLength": 1, "maxLength": 128}
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "required": ["message"],
                "properties": {"message": {"type": "string", "minLength": 1, "maxLength": 4000}}
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Durable bounded single-agent support turn result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "conversationId",
                    "traceId",
                    "turnId",
                    "reply",
                    "outcome",
                    "citations"
                  ],
                  "properties": {
                    "conversationId": {"type": "string", "format": "uuid", "readOnly": true},
                    "traceId": {"type": "string", "format": "uuid", "readOnly": true},
                    "turnId": {"type": "string", "format": "uuid", "readOnly": true},
                    "reply": {"type": "string", "maxLength": 256},
                    "outcome": {
                      "type": "string",
                      "enum": [
                        "completed",
                        "budget_exhausted",
                        "provider_denied",
                        "retrieval_denied"
                      ]
                    },
                    "citations": {
                      "type": "array",
                      "maxItems": 3,
                      "items": {"$ref": "#/components/schemas/RetrievalCitation"},
                      "description": "Source references projected only from sufficient retrieval evidence committed with this turn."
                    }
                  }
                }
              }
            }
          },
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "403": {"$ref": "#/components/responses/Forbidden"},
          "409": {"$ref": "#/components/responses/Conflict"},
          "422": {"$ref": "#/components/responses/InvalidRequest"},
          "503": {"$ref": "#/components/responses/Unavailable"}
        }
      }
    },
    "/api/chat/stream": {
      "post": {
        "operationId": "streamSupportTurn",
        "security": [{"directUserBearer": []}],
        "parameters": [
          {
            "name": "X-Session-Id",
            "in": "header",
            "required": true,
            "schema": {"type": "string", "minLength": 1, "maxLength": 64}
          },
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": true,
            "schema": {"type": "string", "minLength": 1, "maxLength": 128}
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "required": ["message"],
                "properties": {"message": {"type": "string", "minLength": 1, "maxLength": 4000}}
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bounded filtered projection of one durable support turn",
            "content": {
              "text/event-stream": {
                "schema": {"type": "string"},
                "x-sse-events": {
                  "token": {"$ref": "#/components/schemas/SseTokenData"},
                  "action_receipt": {"$ref": "#/components/schemas/SseActionReceiptData"},
                  "done": {"$ref": "#/components/schemas/SseDoneData"},
                  "error": {"$ref": "#/components/schemas/SseErrorData"}
                }
              }
            }
          },
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "403": {"$ref": "#/components/responses/Forbidden"},
          "409": {"$ref": "#/components/responses/Conflict"},
          "422": {"$ref": "#/components/responses/InvalidRequest"},
          "503": {"$ref": "#/components/responses/Unavailable"}
        }
      }
    },
    "/api/feedback": {
      "post": {
        "operationId": "appendSupportFeedback",
        "security": [{"directUserBearer": []}],
        "parameters": [
          {
            "name": "X-Session-Id",
            "in": "header",
            "required": true,
            "schema": {"type": "string", "minLength": 1, "maxLength": 64}
          },
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": true,
            "schema": {"type": "string", "minLength": 1, "maxLength": 128}
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {"schema": {"$ref": "#/components/schemas/FeedbackRequest"}}
          }
        },
        "responses": {
          "201": {
            "description": "One immutable owner-authorized feedback signal",
            "content": {
              "application/json": {"schema": {"$ref": "#/components/schemas/FeedbackResponse"}}
            }
          },
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "403": {"$ref": "#/components/responses/Forbidden"},
          "409": {"$ref": "#/components/responses/Conflict"},
          "422": {"$ref": "#/components/responses/InvalidRequest"},
          "503": {"$ref": "#/components/responses/Unavailable"}
        }
      }
    },
    "/api/eval/evidence/{traceId}": {
      "get": {
        "operationId": "getAgentEvaluationEvidence",
        "x-citybuddy-profile": "evaluation",
        "security": [{"evaluationManagementBasic": []}],
        "parameters": [
          {
            "name": "traceId",
            "in": "path",
            "required": true,
            "schema": {"type": "string", "format": "uuid", "minLength": 36, "maxLength": 36}
          },
          {
            "name": "X-Eval-Sandbox-Id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Bounded read-only projection of complete authoritative cs_db evidence in persisted sequence order",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/AgentEvaluationEvidence"}
              }
            }
          },
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "404": {"$ref": "#/components/responses/EvaluationEvidenceNotFound"},
          "409": {"$ref": "#/components/responses/EvaluationEvidenceUnavailable"},
          "422": {"$ref": "#/components/responses/InvalidRequest"},
          "503": {"$ref": "#/components/responses/Unavailable"}
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "directUserBearer": {"type": "http", "scheme": "bearer", "bearerFormat": "RS256 JWT"},
      "evaluationManagementBasic": {
        "type": "http",
        "scheme": "basic",
        "description": "Independent evaluation API credential; never a direct-user or service-token fallback."
      }
    },
    "schemas": {
      "PublicError": {
        "type": "object",
        "additionalProperties": false,
        "required": ["detail"],
        "properties": {"detail": {"type": "string", "maxLength": 64}}
      },
      "RetrievalCitation": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sourceId", "chunkId", "sourceVersion", "docType", "title"],
        "properties": {
          "sourceId": {"type": "string", "minLength": 1, "maxLength": 128},
          "chunkId": {"type": "string", "minLength": 1, "maxLength": 128},
          "sourceVersion": {"type": "integer", "minimum": 1},
          "docType": {"type": "string", "enum": ["faq", "product"]},
          "title": {"type": "string", "minLength": 1, "maxLength": 200}
        }
      },
      "SseTokenData": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sequence", "text"],
        "properties": {
          "sequence": {"type": "integer", "minimum": 1, "maximum": 4},
          "text": {"type": "string", "minLength": 1, "maxLength": 64}
        },
        "description": "Bounded non-authoritative explanation prose; clients must not infer action status from token text."
      },
      "SseActionReceiptData": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sequence", "receiptId", "status"],
        "properties": {
          "sequence": {"type": "integer", "minimum": 1, "maximum": 5},
          "receiptId": {"type": "string", "format": "uuid", "readOnly": true},
          "status": {"type": "string", "enum": ["SUCCEEDED"]}
        },
        "description": "The only public action-status carrier, reserved for verified ActionReceipt truth in CB-120/CB-121; CB-082 does not emit it."
      },
      "SseDoneData": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sequence", "conversationId", "traceId", "turnId", "outcome"],
        "properties": {
          "sequence": {"type": "integer", "minimum": 1, "maximum": 5},
          "conversationId": {"type": "string", "format": "uuid", "readOnly": true},
          "traceId": {"type": "string", "format": "uuid", "readOnly": true},
          "turnId": {"type": "string", "format": "uuid", "readOnly": true},
          "outcome": {"type": "string", "enum": ["completed"]}
        }
      },
      "SseErrorData": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sequence", "code"],
        "properties": {
          "sequence": {"type": "integer", "const": 1},
          "code": {
            "type": "string",
            "enum": [
              "attempt_budget_exhausted",
              "provider_unavailable",
              "stream_unavailable",
              "unsafe_output"
            ]
          }
        }
      },
      "FeedbackRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["traceId", "rating"],
        "properties": {
          "traceId": {"type": "string", "format": "uuid"},
          "rating": {"type": "string", "enum": ["POSITIVE", "NEGATIVE"]},
          "comment": {"type": "string", "minLength": 1, "maxLength": 1000}
        }
      },
      "FeedbackResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["feedbackId", "traceId", "rating"],
        "properties": {
          "feedbackId": {"type": "string", "format": "uuid", "readOnly": true},
          "traceId": {"type": "string", "format": "uuid", "readOnly": true},
          "rating": {"type": "string", "enum": ["POSITIVE", "NEGATIVE"]}
        }
      },
      "AgentEvaluationEvidence": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schemaVersion",
          "traceId",
          "sessionId",
          "turnId",
          "terminalOutcome",
          "events",
          "feedback"
        ],
        "properties": {
          "schemaVersion": {"type": "string", "const": "agent-evidence-v1"},
          "traceId": {"type": "string", "format": "uuid", "readOnly": true},
          "sessionId": {"type": "string", "minLength": 1, "maxLength": 64, "readOnly": true},
          "turnId": {"type": "string", "format": "uuid", "readOnly": true},
          "terminalOutcome": {
            "type": "string",
            "enum": [
              "completed",
              "budget_exhausted",
              "provider_denied",
              "retrieval_denied",
              "failed"
            ]
          },
          "events": {
            "type": "array",
            "minItems": 2,
            "maxItems": 48,
            "items": {"$ref": "#/components/schemas/AgentEvaluationEvent"},
            "description": "Complete accepted-to-terminal sequence ordered only by persisted support_event.sequence."
          },
          "retrieval": {"$ref": "#/components/schemas/AgentEvaluationRetrieval"},
          "feedback": {
            "type": "array",
            "maxItems": 8,
            "items": {"$ref": "#/components/schemas/AgentEvaluationFeedback"}
          }
        },
        "description": "Fixed safe projection. It excludes user text, prompts, model/reasoning payloads, providers and aliases, credentials, raw tool or retrieval payloads, PII maps, commerce data, SQL, and internal errors."
      },
      "AgentEvaluationEvent": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sequence", "eventKind", "occurredAt"],
        "properties": {
          "sequence": {"type": "integer", "minimum": 1, "maximum": 48},
          "eventKind": {
            "type": "string",
            "enum": [
              "USER_INPUT",
              "ROUTING_DECISION",
              "BUDGET_CHARGED",
              "CIRCUIT_OUTCOME",
              "MODEL_OUTCOME",
              "TOOL_LIFECYCLE",
              "TOOL_DENIED",
              "RETRIEVAL_DECISION",
              "AGENT_OUTCOME",
              "ASSISTANT_RESPONSE",
              "TURN_COMPLETED",
              "TURN_FAILED"
            ]
          },
          "outcome": {"type": "string", "minLength": 1, "maxLength": 32},
          "reference": {"type": "string", "minLength": 1, "maxLength": 128},
          "attempt": {"type": "integer", "minimum": 1, "maximum": 32},
          "attemptLimit": {"type": "integer", "minimum": 1, "maximum": 32},
          "occurredAt": {"type": "string", "format": "date-time", "readOnly": true}
        }
      },
      "AgentEvaluationRetrieval": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "outcome",
          "reason",
          "indexVersion",
          "calibrationVersion",
          "candidateCount",
          "evidenceCount",
          "sources"
        ],
        "properties": {
          "outcome": {"type": "string", "enum": ["SUFFICIENT", "INSUFFICIENT"]},
          "reason": {
            "type": "string",
            "enum": [
              "sufficient",
              "empty_candidates",
              "below_threshold",
              "ambiguous_margin",
              "reranker_denied"
            ]
          },
          "indexVersion": {"type": "string", "minLength": 1, "maxLength": 64},
          "calibrationVersion": {"type": "string", "minLength": 1, "maxLength": 64},
          "candidateCount": {"type": "integer", "minimum": 0, "maximum": 5},
          "evidenceCount": {"type": "integer", "minimum": 0, "maximum": 3},
          "sources": {
            "type": "array",
            "maxItems": 3,
            "items": {"$ref": "#/components/schemas/AgentEvaluationSource"}
          }
        }
      },
      "AgentEvaluationSource": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rank", "sourceId", "chunkId", "sourceVersion", "docType"],
        "properties": {
          "rank": {"type": "integer", "minimum": 1, "maximum": 3},
          "sourceId": {"type": "string", "minLength": 1, "maxLength": 128},
          "chunkId": {"type": "string", "minLength": 1, "maxLength": 128},
          "sourceVersion": {"type": "integer", "minimum": 1},
          "docType": {"type": "string", "enum": ["faq", "product"]}
        }
      },
      "AgentEvaluationFeedback": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rating", "occurredAt"],
        "properties": {
          "rating": {"type": "string", "enum": ["POSITIVE", "NEGATIVE"]},
          "occurredAt": {"type": "string", "format": "date-time", "readOnly": true}
        },
        "description": "Safe append-only rating projection; private feedback comment text is excluded."
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Invalid direct-user identity or production evaluation context",
        "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PublicError"}}}
      },
      "Forbidden": {
        "description": "Permission or persisted session ownership rejected",
        "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PublicError"}}}
      },
      "Conflict": {
        "description": "Idempotency conflict or a bounded concurrent turn still in progress",
        "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PublicError"}}}
      },
      "InvalidRequest": {
        "description": "Malformed or unknown request field",
        "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PublicError"}}}
      },
      "Unavailable": {
        "description": "Durable support truth is unavailable or the turn previously failed",
        "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PublicError"}}}
      },
      "EvaluationEvidenceNotFound": {
        "description": "Unknown and cross-sandbox traces share the same concealed result",
        "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PublicError"}}}
      },
      "EvaluationEvidenceUnavailable": {
        "description": "Persisted evidence is incomplete, conflicting, oversized, or not safely projectable",
        "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PublicError"}}}
      }
    }
  }
}
