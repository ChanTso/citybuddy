# Required: synthetic bootstrap credential generated by `make init-local`.
MYSQL_BOOTSTRAP_PASSWORD=
# Required: synthetic auth migration credential generated by `make init-local`.
MYSQL_AUTH_MIGRATION_PASSWORD=
# Required: synthetic commerce migration credential generated by `make init-local`.
MYSQL_COMMERCE_MIGRATION_PASSWORD=
# Required: synthetic agent migration credential generated by `make init-local`.
MYSQL_AGENT_MIGRATION_PASSWORD=
# Required: synthetic auth runtime credential generated by `make init-local`.
MYSQL_AUTH_APP_PASSWORD=
# Required: synthetic commerce runtime credential generated by `make init-local`.
MYSQL_COMMERCE_APP_PASSWORD=
# Required: synthetic agent runtime credential generated by `make init-local`.
MYSQL_AGENT_APP_PASSWORD=
# Optional host port for local access; `make init-local` writes 3306.
MYSQL_PORT=
