{
  "openapi": "3.1.0",
  "info": {"title": "CityBuddy commerce API", "version": "CB-105"},
  "paths": {
    "/api/products": {
      "get": {
        "operationId": "listPublishedProducts",
        "security": [{"directUserBearer": []}],
        "parameters": [
          {
            "name": "X-Eval-Sandbox-Id",
            "in": "header",
            "required": false,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Published products with live commerce fields",
            "content": {
              "application/json": {
                "schema": {"type": "array", "items": {"$ref": "#/components/schemas/Product"}}
              }
            }
          },
          "401": {"description": "Invalid direct-user identity or production evaluation context"}
        }
      }
    },
    "/api/products/{productId}": {
      "get": {
        "operationId": "getPublishedProduct",
        "security": [{"directUserBearer": []}],
        "parameters": [
          {"name": "productId", "in": "path", "required": true, "schema": {"type": "string", "minLength": 1}},
          {"name": "X-Eval-Sandbox-Id", "in": "header", "required": false, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {
            "description": "Published product with live commerce fields",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Product"}}}
          },
          "401": {"description": "Invalid direct-user identity or production evaluation context"},
          "404": {"description": "Missing or unpublished product"}
        }
      }
    },
    "/internal/tools/catalog.product.get": {
      "post": {
        "operationId": "getPublishedProductForAgent",
        "security": [{"agentOboBearer": []}],
        "parameters": [
          {
            "name": "X-Support-Session-Id",
            "in": "header",
            "required": true,
            "schema": {"type": "string", "minLength": 1, "maxLength": 64}
          },
          {
            "name": "X-Eval-Sandbox-Id",
            "in": "header",
            "required": false,
            "schema": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,63}$"}
          },
          {
            "name": "X-Agent-Trace-Id",
            "in": "header",
            "required": false,
            "schema": {"type": "string", "maxLength": 64}
          },
          {
            "name": "X-Agent-Operation-Id",
            "in": "header",
            "required": false,
            "schema": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/CatalogProductToolInput"}
            }
          }
        },
        "responses": {
          "200": {
            "description": "ToolSpec-bounded published product view",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/CatalogProductToolOutput"}
              }
            }
          },
          "400": {"description": "Unknown or malformed ToolSpec input"},
          "403": {"description": "Invalid OBO mode, scope, actor, session, or context"},
          "404": {"description": "Unknown tool or unpublished product"},
          "503": {"description": "Authoritative product or audit persistence unavailable"}
        }
      }
    },
    "/api/eval/reset": {
      "post": {
        "operationId": "resetEvaluationSandbox",
        "x-citybuddy-profile": "evaluation",
        "security": [{"evaluationManagementBasic": []}],
        "parameters": [
          {"name": "Idempotency-Key", "in": "header", "required": true, "schema": {"type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"}}
        ],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EvaluationResetRequest"}}}
        },
        "responses": {
          "200": {"description": "One-time sandbox activated or same completed reset replayed", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EvaluationResetResponse"}}}},
          "400": {"description": "Invalid bounded reset intent"},
          "401": {"description": "Invalid independent management credential"},
          "409": {"description": "Conflicting or terminal reset intent"},
          "502": {"description": "Identity provisioning rejected without active sandbox"},
          "503": {"description": "Fixture, compensation, or activation closure unavailable"}
        }
      }
    },
    "/api/eval/sandboxes/{sandboxId}/complete": {
      "post": {
        "operationId": "completeEvaluationSandbox",
        "x-citybuddy-profile": "evaluation",
        "security": [{"evaluationManagementBasic": []}],
        "parameters": [
          {"name": "sandboxId", "in": "path", "required": true, "schema": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,63}$"}},
          {"name": "Idempotency-Key", "in": "header", "required": true, "schema": {"type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"}}
        ],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EvaluationCompleteRequest"}}}
        },
        "responses": {
          "200": {"description": "Sandbox dead with identity invalidation proven", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EvaluationCompleteResponse"}}}},
          "401": {"description": "Invalid independent management credential"},
          "404": {"description": "Unknown or cross-case sandbox"},
          "409": {"description": "Conflicting, provisioning, or inconsistent completion"},
          "503": {"description": "Revocation not yet safely closed"}
        }
      }
    },
    "/api/eval/state": {
      "get": {
        "operationId": "getEvaluationCommerceState",
        "x-citybuddy-profile": "evaluation",
        "security": [{"evaluationManagementBasic": []}],
        "parameters": [
          {"name": "X-Eval-Sandbox-Id", "in": "header", "required": true, "schema": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,63}$"}}
        ],
        "responses": {
          "200": {"description": "Bounded authoritative commerce sandbox state", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EvaluationStateResponse"}}}},
          "400": {"description": "Malformed or widened request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EvaluationError"}}}},
          "401": {"description": "Invalid independent management credential", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EvaluationError"}}}},
          "404": {"description": "Unknown sandbox", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EvaluationError"}}}},
          "409": {"description": "Inconsistent or unobservable sandbox truth", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EvaluationError"}}}},
          "503": {"description": "Authoritative commerce state unavailable", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EvaluationError"}}}}
        }
      }
    },
    "/api/eval/audit/{sessionId}": {
      "get": {
        "operationId": "getEvaluationCommerceAuditReferences",
        "x-citybuddy-profile": "evaluation",
        "security": [{"evaluationManagementBasic": []}],
        "parameters": [
          {"name": "sessionId", "in": "path", "required": true, "schema": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,63}$"}},
          {"name": "X-Eval-Sandbox-Id", "in": "header", "required": true, "schema": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,63}$"}},
          {"name": "after", "in": "query", "required": false, "schema": {"type": "integer", "minimum": 1}},
          {"name": "limit", "in": "query", "required": false, "schema": {"type": "integer", "minimum": 1, "maximum": 50, "default": 20}}
        ],
        "responses": {
          "200": {"description": "Bounded session-associated commerce audit references", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EvaluationAuditPage"}}}},
          "400": {"description": "Malformed, unbounded, or widened request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EvaluationError"}}}},
          "401": {"description": "Invalid independent management credential", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EvaluationError"}}}},
          "404": {"description": "Unknown or unassociated sandbox/session", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EvaluationError"}}}},
          "409": {"description": "Referenced commerce truth is inconsistent", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EvaluationError"}}}},
          "503": {"description": "Authoritative commerce audit unavailable", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EvaluationError"}}}}
        }
      }
    },
    "/api/eval/version": {
      "get": {
        "operationId": "getEvaluationCommerceVersion",
        "x-citybuddy-profile": "evaluation",
        "security": [{"evaluationManagementBasic": []}],
        "responses": {
          "200": {"description": "Fixed server-owned evaluation compatibility identifiers", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EvaluationVersionResponse"}}}},
          "400": {"description": "Caller-selected version or capability rejected", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EvaluationError"}}}},
          "401": {"description": "Invalid independent management credential", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EvaluationError"}}}},
          "503": {"description": "Startup-validated schema compatibility unavailable", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EvaluationError"}}}}
        }
      }
    },
    "/internal/eval/sandboxes/{sandboxId}/liveness": {
      "post": {
        "operationId": "assertEvaluationSandboxLiveness",
        "x-citybuddy-profile": "evaluation",
        "security": [{"directUserBearer": []}],
        "parameters": [
          {"name": "sandboxId", "in": "path", "required": true, "schema": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,63}$"}},
          {"name": "X-Eval-Sandbox-Id", "in": "header", "required": true, "schema": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,63}$"}}
        ],
        "responses": {
          "204": {"description": "Token, header, path, and ACTIVE commerce truth agree"},
          "403": {"description": "Identity, sandbox, or liveness mismatch"}
        }
      }
    },
    "/api/orders/{orderId}/mock-payment": {
      "post": {
        "operationId": "startMockPayment",
        "security": [{"directUserBearer": []}],
        "parameters": [
          {"name": "orderId", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}},
          {"name": "Idempotency-Key", "in": "header", "required": true, "schema": {"$ref": "#/components/schemas/BoundedPaymentIdentifier"}},
          {"name": "X-Eval-Sandbox-Id", "in": "header", "required": false, "description": "Required only for an evaluation direct-user token and must equal its signed sandbox claim and persisted order sandbox.", "schema": {"$ref": "#/components/schemas/PaymentSandboxId"}}
        ],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/MockPaymentRequest"}}}},
        "responses": {
          "200": {"description": "Same owner, sandbox, key, and canonical intent replay", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/MockPaymentResult"}}}},
          "201": {"description": "One eligible payment attempt created", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/MockPaymentResult"}}}},
          "400": {"description": "Malformed or out-of-bounds payment intent", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PaymentError"}}}},
          "401": {"description": "Invalid direct-user identity", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PaymentError"}}}},
          "403": {"description": "Invalid permission, production evaluation context, or inactive evaluation sandbox", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PaymentError"}}}},
          "404": {"description": "Missing or non-owned order", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PaymentError"}}}},
          "409": {"description": "Ineligible order or conflicting idempotency/correlation", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PaymentError"}}}},
          "503": {"description": "Authoritative payment or sandbox truth unavailable", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PaymentError"}}}}
        }
      }
    },
    "/internal/mock-payments/callback": {
      "post": {
        "operationId": "applyMockPaymentCallback",
        "security": [{"mockPaymentKeyId": [], "mockPaymentSignature": []}],
        "parameters": [
          {"name": "X-Mock-Payment-Timestamp", "in": "header", "required": true, "schema": {"type": "string", "pattern": "^[0-9]{1,19}$"}},
          {"name": "Idempotency-Key", "in": "header", "required": true, "schema": {"$ref": "#/components/schemas/BoundedPaymentIdentifier"}}
        ],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/MockPaymentCallbackRequest"}}}},
        "responses": {
          "200": {"description": "One atomic applied result or same-intent replay", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/MockPaymentCallbackResult"}}}},
          "400": {"description": "Malformed or incomplete bounded callback intent", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PaymentError"}}}},
          "401": {"description": "Missing, stale, or invalid independent callback signature", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PaymentError"}}}},
          "403": {"description": "Evaluation callback unavailable or sandbox inactive", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PaymentError"}}}},
          "404": {"description": "Unknown callback correlation", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PaymentError"}}}},
          "409": {"description": "Correlation, replay, or legal-transition conflict", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PaymentError"}}}},
          "503": {"description": "Authoritative payment or sandbox truth unavailable", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PaymentError"}}}}
        }
      }
    },
    "/api/orders": {
      "post": {
        "operationId": "createStandardOrder",
        "security": [{"directUserBearer": []}],
        "parameters": [
          {"name": "Idempotency-Key", "in": "header", "required": true, "schema": {"type": "string", "minLength": 1, "maxLength": 128}},
          {"name": "X-Correlation-Id", "in": "header", "required": false, "schema": {"type": "string", "pattern": "^[A-Za-z0-9._-]{1,64}$"}},
          {"name": "X-Eval-Sandbox-Id", "in": "header", "required": false, "schema": {"type": "string"}}
        ],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/CreateOrderRequest"}}}
        },
        "responses": {
          "200": {"description": "Same user, key, and canonical intent replay", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/StandardOrder"}}}},
          "201": {"description": "Atomically created standard order", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/StandardOrder"}}}},
          "400": {"description": "Validation rejection", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OrderError"}}}},
          "401": {"description": "Authentication rejection", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OrderError"}}}},
          "403": {"description": "Authorization or ownership rejection", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OrderError"}}}},
          "409": {"description": "Idempotency, stale-version, or insufficient-stock rejection", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OrderError"}}}},
          "422": {"description": "Missing, unpublished, or unavailable authoritative product", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OrderError"}}}},
          "429": {"description": "Committed truth remains indeterminate after bounded concurrency recovery", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OrderError"}}}},
          "503": {"description": "Authoritative order database unavailable", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OrderError"}}}}
        }
      }
    },
    "/api/seckill/activities/{activityId}/reservations": {
      "post": {
        "operationId": "createSeckillReservation",
        "security": [{"directUserBearer": []}],
        "parameters": [
          {"name": "activityId", "in": "path", "required": true, "schema": {"type": "string", "minLength": 1, "maxLength": 64}},
          {"name": "Idempotency-Key", "in": "header", "required": true, "schema": {"type": "string", "minLength": 1, "maxLength": 128}},
          {"name": "X-Eval-Sandbox-Id", "in": "header", "required": false, "schema": {"type": "string"}}
        ],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SeckillReservationRequest"}}}
        },
        "responses": {
          "200": {"description": "Owned idempotent replay or durable ordered result", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SeckillReservation"}}}},
          "201": {"description": "Admission marker committed; durable order is not yet claimed", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SeckillReservation"}}}},
          "202": {"description": "Owned reservation is pending a bounded transaction outcome", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SeckillReservation"}}}},
          "400": {"description": "Validation or body-identity rejection", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SeckillError"}}}},
          "401": {"description": "Authentication rejection", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SeckillError"}}}},
          "403": {"description": "Authorization rejection", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SeckillError"}}}},
          "409": {"description": "Explicit rejected reservation or idempotency conflict", "content": {"application/json": {"schema": {"oneOf": [{"$ref": "#/components/schemas/SeckillReservation"}, {"$ref": "#/components/schemas/SeckillError"}]}}}},
          "503": {"description": "Transaction admission transport unavailable", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SeckillError"}}}}
        }
      }
    },
    "/api/reservations/{reservationId}": {
      "get": {
        "operationId": "getOwnedSeckillReservation",
        "security": [{"directUserBearer": []}],
        "parameters": [
          {"name": "reservationId", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}},
          {"name": "X-Eval-Sandbox-Id", "in": "header", "required": false, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Owned durable reservation status", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SeckillReservation"}}}},
          "400": {"description": "Invalid reservation identifier", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SeckillError"}}}},
          "401": {"description": "Authentication rejection", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SeckillError"}}}},
          "403": {"description": "Authorization rejection", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SeckillError"}}}},
          "404": {"description": "Unknown or cross-user reservation", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SeckillError"}}}}
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "directUserBearer": {"type": "http", "scheme": "bearer", "bearerFormat": "JWT"},
      "agentOboBearer": {"type": "http", "scheme": "bearer", "bearerFormat": "Agent OBO JWT"},
      "evaluationManagementBasic": {"type": "http", "scheme": "basic"},
      "mockPaymentKeyId": {"type": "apiKey", "in": "header", "name": "X-Mock-Payment-Key-Id"},
      "mockPaymentSignature": {"type": "apiKey", "in": "header", "name": "X-Mock-Payment-Signature", "description": "HMAC-SHA256 over the timestamp, idempotency key, complete callback intent, and exact evaluation context when present."}
    },
    "schemas": {
      "EvaluationProductFixture": {
        "type": "object",
        "additionalProperties": false,
        "required": ["productId", "name", "description", "priceMinor", "currency", "stockQuantity", "available"],
        "properties": {
          "productId": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,63}$"},
          "name": {"type": "string", "minLength": 1, "maxLength": 200},
          "description": {"type": "string", "minLength": 1, "maxLength": 1000},
          "priceMinor": {"type": "integer", "minimum": 1, "maximum": 1000000000},
          "currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
          "stockQuantity": {"type": "integer", "minimum": 0, "maximum": 1000000},
          "available": {"type": "boolean"}
        }
      },
      "EvaluationPaymentOrderFixture": {
        "type": "object",
        "additionalProperties": false,
        "required": ["orderId", "productId", "quantity"],
        "properties": {
          "orderId": {"type": "string", "format": "uuid"},
          "productId": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,63}$"},
          "quantity": {"type": "integer", "minimum": 1, "maximum": 100}
        }
      },
      "EvaluationResetRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sandboxId", "caseCorrelation", "ttlSeconds", "testUserLabel", "products"],
        "properties": {
          "sandboxId": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,63}$"},
          "caseCorrelation": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"},
          "ttlSeconds": {"type": "integer", "minimum": 60, "maximum": 3600},
          "testUserLabel": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"},
          "products": {"type": "array", "minItems": 1, "maxItems": 16, "items": {"$ref": "#/components/schemas/EvaluationProductFixture"}},
          "paymentOrder": {"$ref": "#/components/schemas/EvaluationPaymentOrderFixture", "description": "Optional server-controlled evaluation payment fixture bound to the provisioned test principal and one listed product."}
        }
      },
      "EvaluationResetResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sandboxId", "testUserHandle"],
        "properties": {
          "sandboxId": {"type": "string", "maxLength": 64},
          "testUserHandle": {"type": "string", "pattern": "^[A-Za-z0-9_-]{43}$"}
        }
      },
      "EvaluationCompleteRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["caseCorrelation"],
        "properties": {
          "caseCorrelation": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"}
        }
      },
      "EvaluationCompleteResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sandboxId", "state"],
        "properties": {
          "sandboxId": {"type": "string", "maxLength": 64},
          "state": {"type": "string", "enum": ["DEAD"]}
        }
      },
      "EvaluationSandboxState": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sandboxId", "lifecycleState", "authInvalidationState", "deathReason", "fixtureCount", "expiresAt", "activatedAt", "deadAt", "closedAt", "version"],
        "properties": {
          "sandboxId": {"type": "string", "maxLength": 64},
          "lifecycleState": {"type": "string", "enum": ["ACTIVE", "DEAD"]},
          "authInvalidationState": {"type": "string", "enum": ["UNPROVISIONED", "PROVISIONED", "REVOKED", "EXPIRY_PROVEN"]},
          "deathReason": {"type": ["string", "null"], "enum": ["RESET_FAILED", "COMPLETED", "EXPIRED", "ABANDONED", null]},
          "fixtureCount": {"type": "integer", "minimum": 1, "maximum": 16},
          "expiresAt": {"type": ["string", "null"], "format": "date-time"},
          "activatedAt": {"type": ["string", "null"], "format": "date-time"},
          "deadAt": {"type": ["string", "null"], "format": "date-time"},
          "closedAt": {"type": ["string", "null"], "format": "date-time"},
          "version": {"type": "integer", "minimum": 1}
        }
      },
      "EvaluationStateProduct": {
        "type": "object",
        "additionalProperties": false,
        "required": ["productId", "name", "description", "priceMinor", "currency", "stockQuantity", "available", "publicationVersion"],
        "properties": {
          "productId": {"type": "string", "maxLength": 64},
          "name": {"type": "string", "maxLength": 200},
          "description": {"type": "string", "maxLength": 1000},
          "priceMinor": {"type": "integer", "minimum": 1},
          "currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
          "stockQuantity": {"type": "integer", "minimum": 0, "maximum": 1000000},
          "available": {"type": "boolean"},
          "publicationVersion": {"type": "integer", "minimum": 1}
        }
      },
      "EvaluationStateEffect": {
        "type": "object",
        "additionalProperties": false,
        "required": ["effectType", "outcome", "createdAt"],
        "properties": {
          "effectType": {"type": "string", "enum": ["SMS"]},
          "outcome": {"type": "string", "enum": ["SUPPRESSED"]},
          "createdAt": {"type": "string", "format": "date-time"}
        }
      },
      "EvaluationStatePayment": {
        "type": "object",
        "additionalProperties": false,
        "required": ["attemptId", "callbackCorrelationId", "orderId", "amountMinor", "currency", "state", "stateVersion", "callbackEventId", "orderStatus", "orderStateVersion", "movementCount"],
        "properties": {
          "attemptId": {"type": "string", "format": "uuid"},
          "callbackCorrelationId": {"type": "string", "format": "uuid"},
          "orderId": {"type": "string", "format": "uuid"},
          "amountMinor": {"type": "integer", "minimum": 1},
          "currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
          "state": {"type": "string", "enum": ["PENDING", "SUCCEEDED"]},
          "stateVersion": {"type": "integer", "minimum": 1, "maximum": 2},
          "callbackEventId": {"type": ["string", "null"], "format": "uuid"},
          "orderStatus": {"type": "string", "enum": ["UNPAID", "PAID"]},
          "orderStateVersion": {"type": "integer", "minimum": 1, "maximum": 2},
          "movementCount": {"type": "integer", "minimum": 0, "maximum": 1}
        }
      },
      "EvaluationStateResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sandbox", "products", "effects", "payments"],
        "properties": {
          "sandbox": {"$ref": "#/components/schemas/EvaluationSandboxState"},
          "products": {"type": "array", "maxItems": 16, "items": {"$ref": "#/components/schemas/EvaluationStateProduct"}},
          "effects": {"type": "array", "maxItems": 8, "description": "Global ascending order by createdAt, then effectType, then the internal stable correlation key", "items": {"$ref": "#/components/schemas/EvaluationStateEffect"}},
          "payments": {"type": "array", "maxItems": 8, "description": "Global ascending order by createdAt, then attemptId.", "items": {"$ref": "#/components/schemas/EvaluationStatePayment"}}
        }
      },
      "EvaluationAuditReference": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sequence", "auditReferenceId", "sandboxId", "supportSessionId", "traceId", "operationId", "entityType", "entityId", "entityVersion", "outcome", "createdAt"],
        "properties": {
          "sequence": {"type": "integer", "minimum": 1},
          "auditReferenceId": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "sandboxId": {"type": "string", "maxLength": 64},
          "supportSessionId": {"type": "string", "maxLength": 64},
          "traceId": {"type": "string", "maxLength": 64},
          "operationId": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "entityType": {"type": "string", "enum": ["PRODUCT_FIXTURE", "PAYMENT_CALLBACK"]},
          "entityId": {"type": "string", "maxLength": 64},
          "entityVersion": {"type": "integer", "minimum": 1},
          "outcome": {"type": "string", "enum": ["OBSERVED"]},
          "createdAt": {"type": "string", "format": "date-time"}
        }
      },
      "EvaluationAuditPage": {
        "type": "object",
        "additionalProperties": false,
        "required": ["entries", "nextCursor"],
        "properties": {
          "entries": {"type": "array", "minItems": 1, "maxItems": 50, "items": {"$ref": "#/components/schemas/EvaluationAuditReference"}},
          "nextCursor": {"type": ["integer", "null"], "minimum": 1}
        }
      },
      "EvaluationVersionResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["buildId", "schemaCompatibility", "capabilities"],
        "properties": {
          "buildId": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,63}$"},
          "schemaCompatibility": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,63}$"},
          "capabilities": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"type": "string", "enum": ["commerce-audit-v1", "commerce-state-v1", "commerce-version-v1"]}}
        }
      },
      "EvaluationError": {
        "type": "object",
        "additionalProperties": false,
        "required": ["error"],
        "properties": {
          "error": {"type": "string", "minLength": 1, "maxLength": 128}
        }
      },
      "BoundedPaymentIdentifier": {"type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"},
      "PaymentSandboxId": {"type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"},
      "MockPaymentRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["amountMinor", "currency"],
        "properties": {
          "amountMinor": {"type": "integer", "minimum": 1},
          "currency": {"type": "string", "pattern": "^[A-Z]{3}$"}
        }
      },
      "MockPaymentResult": {
        "type": "object",
        "additionalProperties": false,
        "required": ["attemptId", "callbackCorrelationId", "orderId", "orderKind", "amountMinor", "currency", "state", "replayed"],
        "properties": {
          "attemptId": {"type": "string", "format": "uuid"},
          "callbackCorrelationId": {"type": "string", "format": "uuid"},
          "orderId": {"type": "string", "format": "uuid"},
          "orderKind": {"type": "string", "enum": ["STANDARD", "SECKILL"]},
          "amountMinor": {"type": "integer", "minimum": 1},
          "currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
          "state": {"type": "string", "enum": ["PENDING", "SUCCEEDED"]},
          "replayed": {"type": "boolean"}
        }
      },
      "MockPaymentCallbackRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["callbackEventId", "callbackCorrelationId", "orderId", "amountMinor", "currency", "outcome"],
        "properties": {
          "callbackEventId": {"type": "string", "format": "uuid"},
          "callbackCorrelationId": {"type": "string", "format": "uuid"},
          "orderId": {"type": "string", "format": "uuid"},
          "amountMinor": {"type": "integer", "minimum": 1},
          "currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
          "outcome": {"const": "SUCCEEDED"},
          "sandboxId": {"$ref": "#/components/schemas/PaymentSandboxId"},
          "supportSessionId": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,63}$"},
          "traceId": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,63}$"},
          "operationId": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        },
        "dependentRequired": {
          "sandboxId": ["supportSessionId", "traceId", "operationId"],
          "supportSessionId": ["sandboxId", "traceId", "operationId"],
          "traceId": ["sandboxId", "supportSessionId", "operationId"],
          "operationId": ["sandboxId", "supportSessionId", "traceId"]
        }
      },
      "MockPaymentCallbackResult": {
        "type": "object",
        "additionalProperties": false,
        "required": ["attemptId", "callbackCorrelationId", "orderId", "state", "replayed"],
        "properties": {
          "attemptId": {"type": "string", "format": "uuid"},
          "callbackCorrelationId": {"type": "string", "format": "uuid"},
          "orderId": {"type": "string", "format": "uuid"},
          "state": {"const": "SUCCEEDED"},
          "replayed": {"type": "boolean"}
        }
      },
      "PaymentError": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category", "message"],
        "properties": {
          "category": {"type": "string", "enum": ["AUTHENTICATION", "AUTHORIZATION", "VALIDATION", "NOT_FOUND", "CONFLICT", "UNAVAILABLE"]},
          "message": {"type": "string", "minLength": 1, "maxLength": 128}
        }
      },
      "Product": {
        "type": "object",
        "additionalProperties": false,
        "required": ["productId", "name", "description", "priceMinor", "currency", "stockQuantity", "available", "publicationVersion"],
        "properties": {
          "productId": {"type": "string"},
          "name": {"type": "string"},
          "description": {"type": "string"},
          "priceMinor": {"type": "integer", "minimum": 0},
          "currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
          "stockQuantity": {"type": "integer", "minimum": 0},
          "available": {"type": "boolean"},
          "publicationVersion": {"type": "integer", "minimum": 1}
        }
      },
      "CatalogProductToolInput": {
        "type": "object",
        "additionalProperties": false,
        "required": ["productId"],
        "properties": {
          "productId": {"type": "string", "minLength": 1, "maxLength": 64}
        }
      },
      "CatalogProductToolOutput": {
        "type": "object",
        "additionalProperties": false,
        "required": ["productId", "name", "priceMinor", "currency", "available", "publicationVersion"],
        "properties": {
          "productId": {"type": "string", "minLength": 1, "maxLength": 64},
          "name": {"type": "string", "minLength": 1, "maxLength": 200},
          "priceMinor": {"type": "integer", "minimum": 0},
          "currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
          "available": {"type": "boolean"},
          "publicationVersion": {"type": "integer", "minimum": 1}
        }
      },
      "CreateOrderRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["productId", "quantity", "expectedProductVersion"],
        "properties": {
          "productId": {"type": "string", "minLength": 1, "maxLength": 64},
          "quantity": {"type": "integer", "minimum": 1, "maximum": 100},
          "expectedProductVersion": {"type": "integer", "minimum": 1}
        }
      },
      "StandardOrder": {
        "type": "object",
        "additionalProperties": false,
        "required": ["orderId", "productId", "productName", "unitPriceMinor", "currency", "quantity", "totalPriceMinor", "productVersion", "status", "correlationId", "replayed"],
        "properties": {
          "orderId": {"type": "string", "format": "uuid"},
          "productId": {"type": "string"},
          "productName": {"type": "string"},
          "unitPriceMinor": {"type": "integer", "minimum": 0},
          "currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
          "quantity": {"type": "integer", "minimum": 1},
          "totalPriceMinor": {"type": "integer", "minimum": 0},
          "productVersion": {"type": "integer", "minimum": 1},
          "status": {"type": "string", "enum": ["UNPAID"]},
          "correlationId": {"type": "string"},
          "replayed": {"type": "boolean"}
        }
      },
      "OrderError": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category", "message", "correlationId"],
        "properties": {
          "category": {"type": "string", "enum": ["AUTHENTICATION", "AUTHORIZATION", "VALIDATION", "OWNERSHIP", "IDEMPOTENCY_CONFLICT", "STALE_VERSION", "INSUFFICIENT_STOCK", "CONCURRENCY_EXHAUSTED", "DEPENDENCY_UNAVAILABLE"]},
          "message": {"type": "string"},
          "correlationId": {"type": "string"}
        }
      },
      "SeckillReservationRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["quantity", "expectedActivityVersion"],
        "properties": {
          "quantity": {"type": "integer", "minimum": 1},
          "expectedActivityVersion": {"type": "integer", "minimum": 1, "maximum": 99999999999999}
        }
      },
      "SeckillReservation": {
        "type": "object",
        "additionalProperties": false,
        "required": ["reservationId", "activityId", "quantity", "activityProjectionVersion", "state", "decisionCode", "projectionVersion", "replay", "durableOrderCreated", "orderId"],
        "properties": {
          "reservationId": {"type": "string", "format": "uuid"},
          "activityId": {"type": "string"},
          "quantity": {"type": "integer", "minimum": 1},
          "activityProjectionVersion": {"type": "integer", "minimum": 1},
          "state": {"type": "string", "enum": ["PENDING", "ADMITTED", "REJECTED", "ORDERED"]},
          "decisionCode": {"type": ["string", "null"], "enum": ["ADMITTED", "ACTIVITY_INACTIVE", "NOT_OPEN", "EXPIRED", "STALE_VERSION", "EXHAUSTED", "DUPLICATE_USER", "TRANSACTION_TIMEOUT", null]},
          "projectionVersion": {"type": "integer", "minimum": 1, "maximum": 3},
          "replay": {"type": "boolean"},
          "durableOrderCreated": {"type": "boolean"},
          "orderId": {"type": ["string", "null"], "format": "uuid"}
        }
      },
      "SeckillError": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category", "message"],
        "properties": {
          "category": {"type": "string", "enum": ["AUTHENTICATION", "AUTHORIZATION", "VALIDATION", "CONFLICT", "UNAVAILABLE"]},
          "message": {"type": "string"}
        }
      }
    }
  }
}
